  "panels": [
    {
      "title": "Gap A — Miners registered",
      "type": "stat",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "count(qfc_inference_tasks_completed)", "refId": "A", "legendFormat": "registered" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "green", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value",
        "graphMode": "area"
      }
    },
    {
      "title": "Gap A — Miner tasks-completed share",
      "description": "Which wallets are actually producing inference work. If one dominates, it's our internal bot, not external adoption.",
      "type": "piechart",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "qfc_inference_tasks_completed", "refId": "A", "legendFormat": "{{miner}}" }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "list" }
      }
    },
    {
      "title": "Gap B — Tasks/sec (5m rate)",
      "type": "timeseries",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(qfc_inference_tasks_completed[5m]))", "refId": "A", "legendFormat": "tasks/sec" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "green", "value": 1.0 }
            ]
          }
        }
      }
    },
    {
      "title": "Gap B — Inference pass rate %",
      "description": "Target: ≥99%. Sustained drops mean miners are serving bad results or verification is rejecting honest work.",
      "type": "stat",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "avg(qfc_inference_pass_rate)", "refId": "A", "legendFormat": "pass" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value"
      }
    },
    {
      "title": "Gap B — Total tasks ever (cumulative)",
      "type": "stat",
      "id": 5,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
