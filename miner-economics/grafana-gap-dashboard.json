          }
        }
      }
    },
    {
      "title": "Gap C — Total FLOPS (cumulative)",
      "description": "Proxy for how much actual compute work has been done — useful for argument 'the chain isn't idle' to external reviewers.",
      "type": "timeseries",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(qfc_inference_flops_total)", "refId": "A", "legendFormat": "FLOPS" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Gap C — Inference score per miner",
      "type": "timeseries",
      "id": 7,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "qfc_inference_score", "refId": "A", "legendFormat": "{{miner}}" }
      ]
